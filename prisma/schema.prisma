generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  phone     String?
  source    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  status    String   @default("new")
  notes     String?
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  name     String
  password String
  role     String @default("admin")
}

model Campaign {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  createdAt   DateTime @default(now())
  status      String   @default("active")
}
