generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  phone     String?
  source    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  status    String   @default("new")
  notes     String?
  metadata  Json?

  conversations Conversation[]
  deals         Deal[]
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  name     String
  password String
  role     String @default("admin")
}

// ============================================================
// Remarketing
// ============================================================

model Audience {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  filters     Json?    // { source: [], status: [], tags: [], dateRange: {} }
  matchCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  campaigns   Campaign[]
}

model Campaign {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  type        String   @default("manual") // manual, automated, drip
  status      String   @default("draft")  // draft, active, paused, completed
  audienceId  Int?
  channelType String?  // whatsapp, email, webchat
  channelId   Int?
  message     String?  @db.Text
  scheduledAt DateTime?
  sentCount   Int      @default(0)
  openCount   Int      @default(0)
  clickCount  Int      @default(0)
  replyCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  audience    Audience? @relation(fields: [audienceId], references: [id])
  actions     CampaignAction[]
}

// ============================================================
// Automations (Flow Builder)
// ============================================================

model Automation {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  status      String   @default("draft") // draft, active, paused
  trigger     String   // new_lead, new_message, deal_stage_changed, manual, schedule
  triggerConfig Json?
  nodes       Json     // React Flow nodes array
  edges       Json     // React Flow edges array
  execCount   Int      @default(0)
  lastRunAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CampaignAction {
  id         Int      @id @default(autoincrement())
  campaignId Int
  leadId     Int?
  action     String   // sent, opened, clicked, replied, converted
  metadata   Json?
  createdAt  DateTime @default(now())
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

// ============================================================
// CRM Pipeline & Deals (Kanban)
// ============================================================

model Pipeline {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  stages    Stage[]
}

model Stage {
  id         Int      @id @default(autoincrement())
  pipelineId Int
  name       String
  color      String   @default("#465FFF")
  position   Int      @default(0)
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals      Deal[]
}

model Deal {
  id          Int      @id @default(autoincrement())
  stageId     Int
  title       String
  value       Float?
  leadId      Int?
  contactName String?
  contactPhone String?
  contactEmail String?
  notes       String?  @db.Text
  tags        String?
  metadata    Json?
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  stage       Stage    @relation(fields: [stageId], references: [id], onDelete: Cascade)
  lead        Lead?    @relation(fields: [leadId], references: [id])
}

model SystemSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// ============================================================
// Multi-Channel Integration
// ============================================================

model Channel {
  id            Int      @id @default(autoincrement())
  type          String   // whatsapp, instagram, messenger, email
  name          String
  status        String   @default("disconnected") // disconnected, qr_code, connected
  config        Json?    // channel-specific config (tokens, phone, page ID, etc.)
  aiEnabled     Boolean  @default(false)
  aiPrompt      String?  @db.Text
  aiModel       String   @default("claude-sonnet-4-6")
  welcomeMessage String? @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  conversations Conversation[]
}

model Conversation {
  id           Int      @id @default(autoincrement())
  channelId    Int
  contactId    String   // phone number, instagram user id, etc.
  contactName  String?
  contactAvatar String?
  mode         String   @default("ai") // ai, human
  status       String   @default("open") // open, closed
  unread       Int      @default(0)
  leadId       Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  channel  Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  lead     Lead?    @relation(fields: [leadId], references: [id])
  messages Message[]

  @@unique([channelId, contactId])
}

model Message {
  id             Int      @id @default(autoincrement())
  conversationId Int
  sender         String   // contact, ai, human
  content        String   @db.Text
  mediaUrl       String?
  mediaType      String?
  timestamp      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}
