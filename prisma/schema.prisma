generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  phone     String?
  source    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  status    String   @default("new")
  notes     String?
  metadata  Json?

  conversations Conversation[]
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  name     String
  password String
  role     String @default("admin")
}

model Campaign {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  createdAt   DateTime @default(now())
  status      String   @default("active")
}

// ============================================================
// WhatsApp Integration
// ============================================================

model WhatsAppInstance {
  id            Int      @id @default(autoincrement())
  name          String
  phone         String?
  status        String   @default("disconnected") // disconnected, qr_code, connected
  qrCode        String?
  sessionData   Json?
  aiEnabled     Boolean  @default(false)
  aiPrompt      String?  @db.Text
  aiModel       String   @default("claude-sonnet-4-6")
  welcomeMessage String? @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  conversations Conversation[]
}

model Conversation {
  id           Int      @id @default(autoincrement())
  instanceId   Int
  contactPhone String
  contactName  String?
  mode         String   @default("ai") // ai, human
  status       String   @default("open") // open, closed
  leadId       Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  instance WhatsAppInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  lead     Lead?           @relation(fields: [leadId], references: [id])
  messages Message[]

  @@unique([instanceId, contactPhone])
}

model Message {
  id             Int      @id @default(autoincrement())
  conversationId Int
  sender         String   // contact, ai, human
  content        String   @db.Text
  mediaUrl       String?
  mediaType      String?
  timestamp      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}
